@{
    Layout = null; // Independent clean screen for login
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - ArchivesSpace G23</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: radial-gradient(circle at top right, #1e1b4b, #0f172a);
        }
        .login-card {
            width: 440px;
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            backdrop-filter: blur(12px);
            padding: 3rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            text-align: center;
        }
        .login-logo {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
        }
        .tab-btn {
            flex: 1;
            padding: 0.6rem;
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-fast);
        }
        .tab-btn.active {
            background-color: var(--bg-surface-elevated);
            color: white;
            border-color: var(--color-primary);
        }
        .tab-container {
            display: flex;
            margin-bottom: 1.5rem;
            border-radius: var(--radius-sm);
            overflow: hidden;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <i data-lucide="archive"></i>
        </div>
        <h2 style="margin-bottom: 0.5rem; color: #fff;">ArchivesSpaceWeb</h2>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem;">G23 Archival Management Platform</p>

        <!-- Validation Summary -->
        <form asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <input type="hidden" name="authMode" id="authModeInput" value="Local" />

            <!-- US 6 & 54: Local vs LDAP Selection Tabs -->
            <div class="tab-container">
                <button type="button" id="tab-local" class="tab-btn active" onclick="setAuthMode('Local')">Autenticación Local</button>
                <button type="button" id="tab-ldap" class="tab-btn" onclick="setAuthMode('LDAP')">LDAP Institucional</button>
            </div>

            <div asp-validation-summary="ModelOnly" class="form-group" style="color: var(--color-danger); text-align: left; font-size: 0.85rem; background: rgba(239, 68, 68, 0.1); padding: 10px; border-radius: 6px;"></div>

            <div class="form-group" style="text-align: left;">
                <label class="form-label">Usuario</label>
                <input type="text" name="username" class="form-control" placeholder="Escribe tu usuario..." required autofocus />
            </div>

            <div class="form-group" style="text-align: left; margin-bottom: 2rem;">
                <label class="form-label">Contraseña</label>
                <input type="password" name="password" class="form-control" placeholder="Escribe tu contraseña..." required />
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; border-radius: var(--radius-sm);">
                Ingresar al Sistema
            </button>
        </form>

        <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <p style="font-size: 0.75rem; color: var(--text-muted);">
                Credenciales demo: <strong>admin</strong> / <strong>password123</strong><br/>
                Para simular LDAP selecciona la pestaña y usa cualquier usuario con contraseña <strong>ldap123</strong>.
            </p>
        </div>
    </div>

    <script>
        lucide.createIcons();

        function setAuthMode(mode) {
            document.getElementById('authModeInput').value = mode;
            
            const btnLocal = document.getElementById('tab-local');
            const btnLdap = document.getElementById('tab-ldap');

            if (mode === 'Local') {
                btnLocal.classList.add('active');
                btnLdap.classList.remove('active');
            } else {
                btnLdap.classList.add('active');
                btnLocal.classList.remove('active');
            }
        }
    </script>
</body>
</html>

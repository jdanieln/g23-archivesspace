@model Resource
@{
    ViewData["Title"] = "Registrar Nuevo Recurso Archivístico";
}

<div style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left"></i> Cancelar y Volver
        </a>
    </div>

    <div class="glass-card">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem; color: #fff;">
            Formulario de Descripción Primaria
        </h3>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Título de la Colección o Recurso</label>
                <input type="text" asp-for="Title" class="form-control" placeholder="Ej. Fondo Documental Manuel Arce" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label class="form-label">Identificador Único</label>
                    <input type="text" asp-for="Identifier" class="form-control" placeholder="Ej. HN-AHN-FMA-001" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Repositorio de Custodia</label>
                    <select asp-for="RepositoryId" required>
                        @foreach (var repo in ViewBag.Repositories)
                        {
                            <option value="@repo.Id">@repo.Name (@repo.Code)</option>
                        }
                    </select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label class="form-label">Fechas Extremas (Dates)</label>
                    <input type="text" asp-for="Dates" class="form-control" placeholder="Ej. 1821 - 1888" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Extensión Física (Extents)</label>
                    <input type="text" asp-for="Extents" class="form-control" placeholder="Ej. 12 Cajas Metálicas" required />
                </div>
            </div>

            <!-- US 27: Level of Description Dropdown with "Other" Toggle -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label class="form-label">Nivel de Descripción</label>
                    <select asp-for="LevelOfDescription" id="levelSelect" onchange="toggleLevelOther()" required>
                        <option value="Collection">Colección (Collection)</option>
                        <option value="Series">Serie (Series)</option>
                        <option value="Subseries">Subserie (Subseries)</option>
                        <option value="File">Expediente (File)</option>
                        <option value="Item">Documento Único (Item)</option>
                        <option value="Other">Otro (Especificar)</option>
                    </select>
                </div>
                <div class="form-group" id="levelOtherGroup" style="display: none;">
                    <label class="form-label">Especificar Otro Nivel</label>
                    <input type="text" asp-for="LevelOfDescriptionOther" id="levelOtherInput" class="form-control" placeholder="Ej. Fondo, Subfondo, etc." />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label class="form-label">Idioma de Descripción</label>
                    <input type="text" asp-for="LanguageOfDescription" class="form-control" placeholder="Ej. Español" value="Español" />
                </div>
                <div class="form-group">
                    <label class="form-label">Autor de la Descripción</label>
                    <input type="text" asp-for="FindingAidAuthor" class="form-control" placeholder="Ej. Daniel Narváez" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Patrocinador del Finding Aid (Sponsor)</label>
                <input type="text" asp-for="FindingAidSponsor" class="form-control" placeholder="Ej. Ministerio de Cultura y Patrimonio" />
            </div>

            <div class="form-group">
                <label class="form-label">Notas Administrativas / Guías de Uso</label>
                <textarea asp-for="FindingAidNote" class="form-control" rows="3" placeholder="Añadir comentarios sobre la restricción, almacenamiento u organización..."></textarea>
            </div>

            <!-- Migration testing source fields (US 7) -->
            <div style="background: rgba(245, 158, 11, 0.05); border: 1px dashed rgba(245, 158, 11, 0.3); padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 2rem;">
                <h4 style="color: var(--color-warning); font-size: 0.9rem; margin-bottom: 0.5rem;">Metadatos de Integridad (Opcional - Migración)</h4>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label class="form-label" style="font-size: 0.8rem;">ID Registro Origen (Archon/AT)</label>
                        <input type="text" asp-for="SourceRecordId" class="form-control" style="padding: 0.5rem; font-size: 0.85rem;" placeholder="Ej. AT-REC-0099" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size: 0.8rem;">Sistema Origen</label>
                        <input type="text" asp-for="SourceSystem" class="form-control" style="padding: 0.5rem; font-size: 0.85rem;" placeholder="Ej. Archivists' Toolkit" />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem;">
                <i data-lucide="save"></i> Guardar Recurso en Base de Datos
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleLevelOther() {
            const select = document.getElementById('levelSelect');
            const group = document.getElementById('levelOtherGroup');
            const input = document.getElementById('levelOtherInput');

            if (select.value === 'Other') {
                group.style.display = 'block';
                input.required = true;
                input.focus();
            } else {
                group.style.display = 'none';
                input.required = false;
                input.value = '';
            }
        }
    </script>
}

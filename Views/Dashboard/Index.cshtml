@model List<Event>
@{
    ViewData["Title"] = "Escritorio de Control";
}

<!-- Repository Scope Notice -->
<div class="glass-card" style="display: flex; justify-content: space-between; align-items: center; border-left: 4px solid var(--color-primary); background: linear-gradient(90deg, rgba(99, 102, 241, 0.08), transparent);">
    <div>
        <h4 style="margin: 0; color: #fff;">Repositorio Activo</h4>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 2px;">
            @ViewBag.ActiveRepositoryName
        </p>
    </div>
    <div style="display: flex; gap: 0.75rem;">
        <a asp-controller="FindingAid" asp-action="Index" class="btn btn-secondary" style="font-size: 0.85rem;">
            <i data-lucide="book-open"></i> Ver Catálogo Público
        </a>
        <a asp-controller="Resource" asp-action="Create" class="btn btn-primary" style="font-size: 0.85rem;">
            <i data-lucide="plus"></i> Registrar Recurso
        </a>
    </div>
</div>

<!-- Statistics Cards -->
<div class="dashboard-grid">
    <div class="stat-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <span class="stat-title">Repositorios</span>
            <i data-lucide="building" style="color: var(--color-secondary); width: 20px; height: 20px;"></i>
        </div>
        <span class="stat-number">@ViewBag.RepositoryCount</span>
    </div>
    <div class="stat-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <span class="stat-title">Recursos</span>
            <i data-lucide="folder-tree" style="color: var(--color-primary); width: 20px; height: 20px;"></i>
        </div>
        <span class="stat-number">@ViewBag.ResourceCount</span>
    </div>
    <div class="stat-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <span class="stat-title">Accessions</span>
            <i data-lucide="file-plus" style="color: var(--color-accent); width: 20px; height: 20px;"></i>
        </div>
        <span class="stat-number">@ViewBag.AccessionCount</span>
    </div>
    <div class="stat-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <span class="stat-title">Agentes</span>
            <i data-lucide="users" style="color: var(--color-warning); width: 20px; height: 20px;"></i>
        </div>
        <span class="stat-number">@ViewBag.AgentCount</span>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.5rem; margin-top: 1rem;">
    <!-- Recent Events Timeline (US 37) -->
    <div class="glass-card">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
            <i data-lucide="activity" style="color: var(--color-accent);"></i>
            <h3 style="margin: 0;">Historial de Eventos del Sistema</h3>
        </div>

        @if (Model != null && Model.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 1.25rem; position: relative; padding-left: 1.5rem; border-left: 2px solid var(--border-color);">
                @foreach (var ev in Model)
                {
                    <div style="position: relative;">
                        <!-- Timeline Bullet -->
                        <span style="position: absolute; left: -29px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background-color: @(ev.EventType == "Login" || ev.EventType == "Logout" ? "var(--color-secondary)" : (ev.EventType == "Creation" ? "var(--color-accent)" : "var(--color-warning)")); box-shadow: 0 0 8px rgba(255,255,255,0.2);"></span>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <strong style="color: #fff; font-size: 0.95rem;">@ev.EventType</strong>
                            <small style="color: var(--text-muted); font-size: 0.75rem;">@ev.EventDate.ToString("yyyy-MM-dd HH:mm:ss")</small>
                        </div>
                        <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 2px;">
                            @ev.Description
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 2rem 0;">
                No hay eventos recientes registrados.
            </p>
        }
    </div>

    <!-- Quick Tooltip Panel -->
    <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
            <i data-lucide="compass" style="color: var(--color-secondary);"></i>
            <h3 style="margin: 0;">Shortcuts de Operaciones</h3>
        </div>
        
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.5rem;">
            Acelera tus tareas administrativas de archivo y migración utilizando los siguientes accesos directos:
        </p>

        <a asp-controller="Import" asp-action="Index" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.8rem 1rem;">
            <i data-lucide="upload-cloud" style="color: var(--color-secondary);"></i>
            <div style="text-align: left;">
                <div style="font-weight: 600; font-size: 0.85rem; color:#fff;">Importar EAD / MARCXML</div>
                <small style="font-size: 0.75rem; color: var(--text-muted);">Carga masiva de descripciones físicas y agentes</small>
            </div>
        </a>

        <a asp-controller="Accession" asp-action="Create" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.8rem 1rem;">
            <i data-lucide="file-plus" style="color: var(--color-accent);"></i>
            <div style="text-align: left;">
                <div style="font-weight: 600; font-size: 0.85rem; color:#fff;">Registrar Accession</div>
                <small style="font-size: 0.75rem; color: var(--text-muted);">Ingreso documental y actas de donaciones</small>
            </div>
        </a>

        @if (User.IsInRole("SystemAdmin"))
        {
            <a asp-controller="Admin" asp-action="Database" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.8rem 1rem;">
                <i data-lucide="database" style="color: var(--color-warning);"></i>
                <div style="text-align: left;">
                    <div style="font-weight: 600; font-size: 0.85rem; color:#fff;">Copia de Seguridad BD</div>
                    <small style="font-size: 0.75rem; color: var(--text-muted);">Hot backup y control de almacenamiento SQLite</small>
                </div>
            </a>
        }
    </div>
</div>

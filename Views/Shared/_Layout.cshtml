<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArchivesSpaceWeb (G23)</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div class="app-wrapper">
        <!-- Sidebar Navigation (US 21 - Enforcing access based on claims) -->
        <aside class="app-sidebar">
            <div class="brand-section">
                <div class="brand-logo">
                    <i data-lucide="archive"></i>
                </div>
                <div class="brand-name">ArchivesSpace G23</div>
            </div>

            <ul class="nav-menu">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i data-lucide="layout-dashboard"></i>
                            <span>Escritorio</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resource" ? "active" : "")">
                        <a asp-controller="Resource" asp-action="Index">
                            <i data-lucide="folder-tree"></i>
                            <span>Recursos (Recs)</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Accession" ? "active" : "")">
                        <a asp-controller="Accession" asp-action="Index">
                            <i data-lucide="file-plus"></i>
                            <span>Accessions (Ingresos)</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agent" ? "active" : "")">
                        <a asp-controller="Agent" asp-action="Index">
                            <i data-lucide="users"></i>
                            <span>Agentes</span>
                        </a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")">
                        <a asp-controller="Import" asp-action="Index">
                            <i data-lucide="upload-cloud"></i>
                            <span>Importaciones</span>
                        </a>
                    </li>

                    @if (User.IsInRole("SystemAdmin"))
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Enums" ? "active" : "")">
                            <a asp-controller="Admin" asp-action="Enums">
                                <i data-lucide="sliders"></i>
                                <span>Administrar Enums</span>
                            </a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                            <a asp-controller="Admin" asp-action="Users">
                                <i data-lucide="user-cog"></i>
                                <span>Usuarios</span>
                            </a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Database" ? "active" : "")">
                            <a asp-controller="Admin" asp-action="Database">
                                <i data-lucide="database"></i>
                                <span>BD & Config</span>
                            </a>
                        </li>
                    }
                }
                
                <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "FindingAid" ? "active" : "")">
                    <a asp-controller="FindingAid" asp-action="Index">
                        <i data-lucide="search"></i>
                        <span>Buscador Público</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                        <span style="font-size: 0.8rem; color: var(--text-muted);">Conectado como:</span>
                        <span style="font-weight: 600; font-size: 0.9rem;">@User.Identity.Name</span>
                        <span style="font-size: 0.75rem; background: var(--bg-surface-elevated); padding: 2px 6px; border-radius: 4px; display: inline-block; align-self: flex-start;">
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                        </span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-secondary" style="margin-top: 0.5rem; justify-content: center; font-size: 0.8rem; padding: 0.4rem;">
                            <i data-lucide="log-out" style="width: 14px; height: 14px;"></i> Salir
                        </a>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i data-lucide="log-in"></i> Iniciar Sesión
                    </a>
                }
            </div>
        </aside>

        <!-- Main Content View -->
        <main class="app-main">
            <!-- Top Navbar -->
            <div class="top-navbar">
                <div>
                    <h2>@ViewData["Title"]</h2>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">Entorno de Trabajo de Archivo G23</span>
                </div>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="navbar-user-section">
                        <!-- US 31: Repository Quick Search -->
                        <form asp-controller="Dashboard" asp-action="Search" method="get" style="display: flex; gap: 0.5rem;">
                            <input type="text" name="query" placeholder="Buscar en repositorio..." class="form-control" style="width: 240px; padding: 0.5rem 1rem; font-size: 0.85rem;" required />
                            <button type="submit" class="btn btn-secondary" style="padding: 0.5rem;"><i data-lucide="search" style="width: 16px; height: 16px;"></i></button>
                        </form>

                        <!-- Floating Help Indicator (US 14) -->
                        <button id="help-toggle-btn" class="btn btn-secondary" style="border-radius: 50%; width: 40px; height: 40px; padding: 0;">
                            <i data-lucide="help-circle" style="color: var(--color-warning);"></i>
                        </button>
                    </div>
                }
            </div>

            <!-- Page Body Render -->
            @RenderBody()

            <!-- Footer Details -->
            <footer style="margin-top: auto; padding-top: 2rem; text-align: center; color: var(--text-muted); font-size: 0.8rem; border-top: 1px solid var(--border-color);">
                <p>&copy; 2026 - ArchivesSpaceWeb (G23). Diseñado con C#, EF Core Code First y SQLite.</p>
            </footer>
        </main>
    </div>

    <!-- Floating Help Panel Slide-Over (US 14 & 22) -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="help-sidebar" class="help-sidebar-container">
            <div class="help-sidebar-header">
                <h3>Centro de Ayuda Contextual</h3>
                <button id="help-close-btn" style="background:none; border:none; color:var(--text-muted); cursor:pointer;">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="help-sidebar-body">
                <div class="help-topic-item">
                    <h4 style="color: var(--color-warning);">Guía del Panel Actual</h4>
                    <p id="help-context-desc" style="font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem;">
                        Cargando ayuda contextual del módulo activo...
                    </p>
                </div>
                <div class="help-topic-item">
                    <h4>Documentación General</h4>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem;">
                        Accede a la base de conocimientos oficial del sistema para guías de administración archivística de recursos.
                    </p>
                    <a id="help-external-link" href="#" target="_blank" class="btn btn-secondary" style="margin-top: 1rem; width:100%;">
                        <i data-lucide="external-link"></i> Abrir Documentación Externa
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Toast Notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-notification success">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast-notification error">
            @TempData["ErrorMessage"]
        </div>
    }

    <style>
        .toast-notification {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            color: white;
            font-weight: 600;
            box-shadow: var(--shadow-lg);
            z-index: 9999;
            animation: slideIn 0.3s ease-out, fadeOut 0.3s 2.7s forwards;
        }
        .toast-notification.success { background-color: var(--color-accent); }
        .toast-notification.error { background-color: var(--color-danger); }
        @@keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @@keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }
    </style>

    <script>
        lucide.createIcons();

        // --- Contextual Help Mapping & Panel Control (US 14 & 22) ---
        const helpToggle = document.getElementById('help-toggle-btn');
        const helpClose = document.getElementById('help-close-btn');
        const helpSidebar = document.getElementById('help-sidebar');
        const helpContextDesc = document.getElementById('help-context-desc');
        const helpExternalLink = document.getElementById('help-external-link');

        // Help URL configuration read from appsettings
        const helpTopicMappings = {
            "Dashboard": { desc: "Estás en el escritorio principal de ArchivesSpace. Aquí puedes ver estadísticas rápidas de registros de archivo y eventos del sistema recientes.", link: "/dashboard-overview" },
            "Resource": { desc: "El gestor de recursos te permite catalogar colecciones documentales, definir fechas y extensiones físicas, enlazar materias, agentes productores, y estructurar la jerarquía física de archivadores.", link: "/managing-resources" },
            "Accession": { desc: "El registro de ingresos (Accessions) registra donaciones, transferencias y transferencias documentales legales hacia el archivo, mapeando el estado e identificadores originales.", link: "/accessioning" },
            "Agent": { desc: "Módulo de gestión de agentes. Permite registrar e identificar personas, familias y organizaciones con rol de Creador, Procedencia o Tema. Soporta exportaciones bajo estándar XML EAC-CPF.", link: "/agent-authority" },
            "Import": { desc: "Módulo de carga masiva XML/CSV. Permite importar descripciones de fondos desde EAD XML, fichas bibliográficas MARCXML y datos de donaciones en formato CSV de forma automatizada.", link: "/importers" },
            "Admin": { desc: "Panel exclusivo del Administrador del Sistema. Permite configurar diccionarios de valor cerrado (Enums), restablecer contraseñas de usuarios locales, y realizar copias de seguridad de la base de datos SQLite.", link: "/admin-settings" }
        };

        if (helpToggle && helpSidebar) {
            helpToggle.addEventListener('click', () => {
                // Determine active section from path
                const path = window.location.pathname;
                let activeSection = "Dashboard";
                if (path.includes("/Resource")) activeSection = "Resource";
                else if (path.includes("/Accession")) activeSection = "Accession";
                else if (path.includes("/Agent")) activeSection = "Agent";
                else if (path.includes("/Import")) activeSection = "Import";
                else if (path.includes("/Admin") || path.includes("/Account")) activeSection = "Admin";

                const config = helpTopicMappings[activeSection];
                helpContextDesc.innerText = config.desc;
                helpExternalLink.href = "https://help.archivesspace.org" + config.link;

                helpSidebar.classList.add('open');
            });

            helpClose.addEventListener('click', () => {
                helpSidebar.classList.remove('open');
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

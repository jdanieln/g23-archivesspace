@model List<ImportLog>
@{
    ViewData["Title"] = "Consola de Importación y Migración";
}

<div class="glass-card" style="display: flex; gap: 1rem; align-items: center; border-left: 4px solid var(--color-secondary); background: linear-gradient(90deg, rgba(14, 165, 233, 0.08), transparent);">
    <div>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
            Carga masiva de colecciones, inventarios, agentes y materias a través de formatos normalizados del estándar de descripción archivística.
        </p>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-top: 1rem;">

    <!-- EAD XML Importer -->
    <div class="glass-card">
        <h4 style="display: flex; align-items: center; gap: 0.5rem; color:#fff; border-bottom:1px solid var(--border-color); padding-bottom:0.5rem; margin-bottom:1rem;">
            <i data-lucide="folder-git" style="color: var(--color-primary);"></i>
            Importador EAD XML
        </h4>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;">
            Carga un archivo XML en formato EAD (de Archivists' Toolkit o Archon) para crear automáticamente un Recurso con su jerarquía.
        </p>
        <form onsubmit="submitImport(event, '/Import/ImportEad')" enctype="multipart/form-data">
            <div class="form-group">
                <label class="form-label" style="font-size: 0.8rem;">Repositorio Destino</label>
                <select name="repositoryId" style="padding: 0.5rem; font-size: 0.85rem;" required>
                    @foreach (var repo in ViewBag.Repositories)
                    {
                        <option value="@repo.Id">@repo.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <input type="file" name="xmlFile" class="form-control" style="padding: 0.4rem; font-size: 0.85rem;" accept=".xml" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 0.85rem; padding: 0.5rem;">
                Procesar Archivo EAD
            </button>
        </form>
    </div>

    <!-- MARCXML Importer -->
    <div class="glass-card">
        <h4 style="display: flex; align-items: center; gap: 0.5rem; color:#fff; border-bottom:1px solid var(--border-color); padding-bottom:0.5rem; margin-bottom:1rem;">
            <i data-lucide="book-open" style="color: var(--color-secondary);"></i>
            Importador MARCXML
        </h4>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;">
            Extrae descripciones bibliográficas MARCXML. Permite crear Recursos completos o filtrar solo materias y agentes.
        </p>
        <form onsubmit="submitImport(event, '/Import/ImportMarcXml')" enctype="multipart/form-data">
            <div class="form-group">
                <label class="form-label" style="font-size: 0.8rem;">Repositorio Destino</label>
                <select name="repositoryId" style="padding: 0.5rem; font-size: 0.85rem;" required>
                    @foreach (var repo in ViewBag.Repositories)
                    {
                        <option value="@repo.Id">@repo.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.75rem;">
                    <input type="checkbox" name="agentsAndSubjectsOnly" value="true" />
                    Importar Solo Agentes y Materias (Subjects)
                </label>
            </div>
            <div class="form-group">
                <input type="file" name="xmlFile" class="form-control" style="padding: 0.4rem; font-size: 0.85rem;" accept=".xml" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 0.85rem; padding: 0.5rem;">
                Procesar MARCXML
            </button>
        </form>
    </div>

    <!-- EAC-CPF Agent Importer & CSV Accessions Importer -->
    <div class="glass-card" style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- EAC-CPF -->
        <div style="border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
            <h4 style="display: flex; align-items: center; gap: 0.5rem; color:#fff; margin-bottom:0.5rem;">
                <i data-lucide="users" style="color: var(--color-warning);"></i>
                Agentes EAC-CPF XML
            </h4>
            <form onsubmit="submitImport(event, '/Import/ImportEacCpf')" enctype="multipart/form-data" style="display: flex; gap: 0.5rem;">
                <input type="file" name="xmlFile" class="form-control" style="padding: 0.4rem; font-size: 0.85rem; flex: 1;" accept=".xml" required />
                <button type="submit" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.5rem;"><i data-lucide="upload"></i></button>
            </form>
        </div>

        <!-- CSV Accessions -->
        <div>
            <h4 style="display: flex; align-items: center; gap: 0.5rem; color:#fff; margin-bottom:0.5rem;">
                <i data-lucide="file-spreadsheet" style="color: var(--color-accent);"></i>
                Accessions CSV Bulk
            </h4>
            <form onsubmit="submitImport(event, '/Accession/ImportCsv')" enctype="multipart/form-data">
                <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem;">
                    <select name="repositoryId" style="padding: 0.4rem; font-size: 0.8rem; width: 140px;" required>
                        @foreach (var repo in ViewBag.Repositories)
                        {
                            <option value="@repo.Id">@repo.Code</option>
                        }
                    </select>
                    <input type="file" name="csvFile" class="form-control" style="padding: 0.4rem; font-size: 0.85rem; flex: 1;" accept=".csv" required />
                </div>
                <button type="submit" class="btn btn-secondary" style="width: 100%; font-size: 0.8rem; padding: 0.4rem;">
                    Importar CSV Donaciones
                </button>
            </form>
        </div>
        
    </div>

</div>

<!-- Historical Logs (US 10: View logs of failures and errors) -->
<div class="glass-card" style="margin-top: 2rem;">
    <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem; color: #fff;">
        Registro Histórico de Importación y Errores
    </h3>

    @if (Model != null && Model.Any())
    {
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-color); color: var(--text-muted); font-size: 0.85rem;">
                        <th style="padding: 0.75rem;">Importador</th>
                        <th style="padding: 0.75rem;">Fecha y Hora</th>
                        <th style="padding: 0.75rem;">Estado</th>
                        <th style="padding: 0.75rem;">Resumen de Operación</th>
                        <th style="padding: 0.75rem; text-align: right;">Reporte de Errores</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr style="border-bottom: 1px solid var(--border-color);">
                            <td style="padding: 0.75rem; font-weight: 600; color: #fff;">@log.ImporterName</td>
                            <td style="padding: 0.75rem;">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td style="padding: 0.75rem;">
                                <span style="background: @(log.Status == "Success" ? "rgba(16, 185, 129, 0.15)" : "rgba(239, 68, 68, 0.15)"); color: @(log.Status == "Success" ? "var(--color-accent)" : "var(--color-danger)"); padding: 2px 6px; border-radius: 4px; font-weight: 600; font-size: 0.8rem;">
                                    @log.Status
                                </span>
                            </td>
                            <td style="padding: 0.75rem; color: var(--text-muted);">@log.Details</td>
                            <td style="padding: 0.75rem; text-align: right;">
                                @if (!string.IsNullOrEmpty(log.ErrorLog))
                                {
                                    <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" onclick="showLogReport('@log.ImporterName', `@log.ErrorLog`)">
                                        Ver Bitácora
                                    </button>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted); font-size: 0.8rem;">Limpio</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="color: var(--text-muted); text-align: center; padding: 2rem 0; font-size: 0.9rem;">
            No hay registros de importación históricos.
        </p>
    }
</div>

<!-- Modal Report logs overlay -->
<div id="log-report-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 9999; align-items: center; justify-content: center;">
    <div class="glass-card" style="width: 700px; max-height: 80vh; display: flex; flex-direction: column; gap: 1rem; border: 1px solid var(--border-color-hover);">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <h3 id="modal-log-title" style="margin: 0;">Reporte de Errores</h3>
            <button class="btn btn-secondary" style="padding: 4px 8px;" onclick="document.getElementById('log-report-modal').style.display = 'none'">Cerrar</button>
        </div>
        <div style="flex: 1; overflow-y: auto; background: #090d16; border-radius: 6px; padding: 1rem; border: 1px solid var(--border-color);">
            <pre id="modal-log-body" style="font-family: monospace; font-size: 0.85rem; color: var(--color-warning); white-space: pre-wrap; margin: 0;"></pre>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showLogReport(importerName, logBody) {
            document.getElementById('modal-log-title').innerText = `Bitácora de Carga - ${importerName}`;
            document.getElementById('modal-log-body').innerText = logBody;
            document.getElementById('log-report-modal').style.display = 'flex';
        }

        function submitImport(event, endpoint) {
            event.preventDefault();
            const form = event.target;
            const formData = new FormData(form);

            fetch(endpoint, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("Éxito: " + data.message);
                    window.location.reload();
                } else {
                    alert("Fallo: " + data.message + (data.errorDetails ? ` (${data.errorDetails})` : ""));
                    window.location.reload();
                }
            })
            .catch(err => {
                alert("Error de conexión al procesar el archivo.");
            });
        }
    </script>
}

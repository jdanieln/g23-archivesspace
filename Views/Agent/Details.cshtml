@model Agent
@{
    ViewData["Title"] = $"Agente: {Model.Name}";
    var resources = ViewBag.Resources as List<ResourceAgent>;
    var accessions = ViewBag.Accessions as List<AccessionAgent>;
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <a asp-action="Index" class="btn btn-secondary">
        <i data-lucide="arrow-left"></i> Volver a la Lista
    </a>
    <div style="display: flex; gap: 0.5rem;">
        <a asp-action="ExportEacCpf" asp-route-id="@Model.Id" class="btn btn-secondary" style="border-color: var(--color-accent); color: var(--color-accent);">
            <i data-lucide="download"></i> Exportar EAC-CPF XML
        </a>
        @if (!User.IsInRole("ReadOnly") && !User.IsInRole("BasicDataEntry"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i data-lucide="edit"></i> Editar Datos
            </a>
        }
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
    
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Core Details Card -->
        <div class="glass-card">
            <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem; color: #fff;">
                Perfil de Registro de Autoridad
            </h3>
            
            <table class="form-group" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 0.75rem; color: var(--text-muted); font-weight: 600; width: 220px;">Nombre Completo / Razón</td>
                    <td style="padding: 0.75rem; font-weight: 600; color: #fff;">@Model.Name</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 0.75rem; color: var(--text-muted); font-weight: 600;">Tipo de Entidad</td>
                    <td style="padding: 0.75rem;">
                        <span style="background: rgba(99, 102, 241, 0.15); color: var(--color-primary); padding: 2px 6px; border-radius: 4px; font-weight: 600;">
                            @Model.Type
                        </span>
                    </td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 0.75rem; color: var(--text-muted); font-weight: 600;">ID de Autoridad (EAC)</td>
                    <td style="padding: 0.75rem; font-family: monospace;">@(Model.AuthorityId ?? "N/D")</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 0.75rem; color: var(--text-muted); font-weight: 600;">Fuente del Nombre (US 50)</td>
                    <td style="padding: 0.75rem;">@(Model.Source ?? "local")</td>
                </tr>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Model.EacCpfXml))
        {
            <!-- EAC-CPF Raw Metadata -->
            <div class="glass-card">
                <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem; color: #fff;">
                    Metadatos EAC-CPF XML Adjuntos
                </h3>
                <pre style="background: var(--bg-surface-elevated); padding: 1rem; border-radius: var(--radius-sm); font-family: monospace; font-size: 0.8rem; overflow-x: auto; color: var(--color-secondary);">@Model.EacCpfXml</pre>
            </div>
        }

    </div>

    <!-- Related Archival Entities (US 35) -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Linked Resources -->
        <div class="glass-card" style="border-top: 4px solid var(--color-secondary);">
            <h4 style="margin-bottom: 0.75rem; color: #fff; display: flex; align-items: center; gap: 0.4rem;">
                <i data-lucide="archive" style="color: var(--color-secondary); width: 18px; height: 18px;"></i>
                Recursos Relacionados
            </h4>
            @if (resources != null && resources.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    @foreach (var res in resources)
                    {
                        <div style="background: var(--bg-surface-elevated); padding: 0.75rem; border-radius: var(--radius-sm); font-size: 0.8rem;">
                            <div style="font-weight: 600; color: #fff;">
                                <a asp-controller="Resource" asp-action="Details" asp-route-id="@res.ResourceId" style="color: #fff; text-decoration: none; border-bottom: 1px dashed var(--border-color);">
                                    @res.Resource?.Title
                                </a>
                            </div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">
                                <span>Rol: <strong style="color: var(--color-secondary);">@res.Role</strong></span>
                                <span>ID: @res.Resource?.Identifier</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: var(--text-muted); font-size: 0.8rem;">Ningún recurso (colección/fondo) relacionado con este agente.</p>
            }
        </div>

        <!-- Linked Accessions -->
        <div class="glass-card" style="border-top: 4px solid var(--color-accent);">
            <h4 style="margin-bottom: 0.75rem; color: #fff; display: flex; align-items: center; gap: 0.4rem;">
                <i data-lucide="clipboard-list" style="color: var(--color-accent); width: 18px; height: 18px;"></i>
                Ingresos Relacionados (Accessions)
            </h4>
            @if (accessions != null && accessions.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    @foreach (var acc in accessions)
                    {
                        <div style="background: var(--bg-surface-elevated); padding: 0.75rem; border-radius: var(--radius-sm); font-size: 0.8rem;">
                            <div style="font-weight: 600; color: #fff;">
                                <a asp-controller="Accession" asp-action="Details" asp-route-id="@acc.AccessionId" style="color: #fff; text-decoration: none; border-bottom: 1px dashed var(--border-color);">
                                    @acc.Accession?.Title
                                </a>
                            </div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">
                                <span>Rol: <strong style="color: var(--color-accent);">@acc.Role</strong></span>
                                <span>ID: @acc.Accession?.Identifier</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: var(--text-muted); font-size: 0.8rem;">Ningún ingreso relacionado con este agente.</p>
            }
        </div>

    </div>

</div>

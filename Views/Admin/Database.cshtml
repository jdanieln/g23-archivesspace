@{
    ViewData["Title"] = "Mantenimiento de Base de Datos y Configuración";
}

<div class="glass-card" style="display: flex; gap: 1rem; align-items: center; border-left: 4px solid var(--color-accent); background: linear-gradient(90deg, rgba(16, 185, 129, 0.08), transparent);">
    <div>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
            Supervisa el almacenamiento físico de la base de datos de demostración SQLite y administra archivos de configuración standalone desacoplados (US 28, 30).
        </p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem;">

    <!-- Left: SQLite Active File & Hot Backups (US 30) -->
    <div class="glass-card">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: #fff; display: flex; align-items: center; gap: 0.5rem;">
            <i data-lucide="database" style="color: var(--color-accent);"></i>
            Base de Datos de Demostración (SQLite)
        </h3>

        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.85rem; margin-bottom: 1.5rem;">
            <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.6rem 0; color: var(--text-muted); font-weight:600;">Estado de Conexión</td>
                <td style="padding: 0.6rem 0; color: var(--color-accent); font-weight:600;">Activa (EF Core)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.6rem 0; color: var(--text-muted); font-weight:600; width: 160px;">Ruta Fisiológica del Archivo</td>
                <td style="padding: 0.6rem 0; font-family: monospace; font-size: 0.8rem; word-break: break-all;">@ViewBag.DatabasePath</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.6rem 0; color: var(--text-muted); font-weight:600;">Tamaño de Base de Datos</td>
                <td style="padding: 0.6rem 0; font-weight: 600; color: #fff;">@ViewBag.DatabaseSize</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.6rem 0; color: var(--text-muted); font-weight:600;">Última Modificación</td>
                <td style="padding: 0.6rem 0;">@ViewBag.LastModified</td>
            </tr>
        </table>

        <!-- Trigger Backup (US 30) -->
        <form asp-action="BackupDatabase" method="post" style="margin-bottom: 2rem;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.75rem;">
                <i data-lucide="shield-check"></i> Realizar Copia de Seguridad Caliente (Hot Backup)
            </button>
        </form>

        <h4 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.4rem; margin-bottom: 0.75rem; color:#fff;">
            Historial de Copias de Seguridad (/backups)
        </h4>
        <div style="max-height: 200px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.4rem;">
            @if (ViewBag.BackupFiles != null && ((List<string>)ViewBag.BackupFiles).Any())
            {
                foreach (var file in ViewBag.BackupFiles)
                {
                    <div style="background: var(--bg-surface-elevated); padding: 0.5rem 0.75rem; border-radius: var(--radius-sm); font-size: 0.8rem; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-family: monospace; color: var(--color-secondary);">@file</span>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">Hot Backup</span>
                    </div>
                }
            }
            else
            {
                <p style="color: var(--text-muted); font-size: 0.8rem; text-align: center; padding: 1rem 0;">
                    Ninguna copia de seguridad creada aún.
                </p>
            }
        </div>
    </div>

    <!-- Right: Standalone / External Configurations (US 28) -->
    <div class="glass-card" style="border-top: 4px solid var(--color-warning);">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: #fff; display: flex; align-items: center; gap: 0.5rem;">
            <i data-lucide="settings" style="color: var(--color-warning);"></i>
            Configuración Standalone Externa (US 28)
        </h3>

        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
            .NET lee la configuración local empaquetada. Para realizar afinamiento del sistema o redirigir el puerto LDAP sin reconstruir el binario de la aplicación, el motor busca el archivo <code>appsettings.external.json</code> en el directorio raíz de ejecución.
        </p>

        <div style="background: #090d16; border: 1px solid var(--border-color); padding: 1rem; border-radius: var(--radius-sm); font-size: 0.8rem; margin-bottom: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                <strong>Estado del archivo externo:</strong>
                <span style="background: rgba(245, 158, 11, 0.15); color: var(--color-warning); padding: 2px 6px; border-radius: 4px; font-weight: 600; font-size: 0.75rem;">
                    Desacoplado Opcional
                </span>
            </div>
            <p style="color: var(--text-muted); font-size: 0.75rem;">
                Ruta buscada: <br/>
                <code style="word-break: break-all; color: var(--color-secondary);">@System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "appsettings.external.json")</code>
            </p>
        </div>

        <h4 style="color:#fff; margin-bottom: 0.5rem;">Plantilla del archivo appsettings.external.json:</h4>
        <pre style="background: #090d16; padding: 1rem; border-radius: 6px; color: var(--color-accent); font-family: monospace; font-size: 0.75rem; border: 1px solid var(--border-color); overflow-x: auto;">
{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CustomDatabaseFile.db"
  },
  "HelpCenterSettings": {
    "BaseHelpUrl": "https://custom-help-center.org"
  },
  "LdapSettings": {
    "MockEnabled": false,
    "Server": "10.0.1.55"
  }
}
        </pre>
    </div>

</div>

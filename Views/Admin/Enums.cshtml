@model List<EnumList>
@{
    ViewData["Title"] = "Gestión de Diccionarios y Valores (Enums)";
}

<div class="glass-card" style="display: flex; gap: 1rem; align-items: center; border-left: 4px solid var(--color-primary); background: linear-gradient(90deg, rgba(99, 102, 241, 0.08), transparent);">
    <div>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
            Administra los valores cerrados cargados desde la base de datos (Code First) para listas desplegables, niveles de descripción, estados y roles de la plataforma (US 3, 13, 17, 18).
        </p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem;">

    <!-- Left: Add Enum Value form & Lists display (US 3, 13, 17) -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Add Enum Value -->
        <div class="glass-card">
            <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: #fff;">
                Agregar Valor a Diccionario
            </h3>
            
            <form asp-action="CreateEnumValue" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Seleccionar Lista</label>
                    <select name="enumListId" required>
                        @foreach (var list in Model)
                        {
                            <option value="@list.Id">@list.Name</option>
                        }
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label class="form-label">Valor (Value)</label>
                        <input type="text" name="value" class="form-control" placeholder="Ej. Subseries" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Etiqueta (Label)</label>
                        <input type="text" name="label" class="form-control" placeholder="Ej. Subserie (Subseries)" required />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    <i data-lucide="plus"></i> Guardar Valor
                </button>
            </form>
        </div>

        <!-- Dictionary Lists Dynamic Displays -->
        <div class="glass-card">
            <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: #fff;">
                Diccionarios del Sistema (DB Loaded)
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 400px; overflow-y: auto;">
                @foreach (var elist in Model)
                {
                    <details style="background: var(--bg-surface-elevated); padding: 0.75rem; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
                        <summary style="font-weight: 600; color: #fff; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
                            <span>@elist.Name</span>
                            <span style="font-size: 0.75rem; color: var(--text-muted); background: var(--bg-base); padding: 2px 6px; border-radius: 4px;">
                                @elist.EnumValues.Count valores
                            </span>
                        </summary>
                        <ul style="list-style: none; margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.85rem; padding-left: 0.5rem;">
                            @foreach (var enumVal in elist.EnumValues)
                            {
                                <li style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border-color); padding: 2px 0;">
                                    <span style="font-family: monospace; color: var(--color-secondary);">@enumVal.Value</span>
                                    <span style="color: var(--text-muted);">@enumVal.Label</span>
                                </li>
                            }
                        </ul>
                    </details>
                }
            </div>
        </div>

    </div>

    <!-- Right: Bulk Update Tool (US 18: Bulk updating one enum value to another) -->
    <div class="glass-card" style="border-top: 4px solid var(--color-warning);">
        <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: #fff; display: flex; align-items: center; gap: 0.5rem;">
            <i data-lucide="shuffle" style="color: var(--color-warning); width: 22px; height: 22px;"></i>
            Actualización Masiva de Enums (US 18)
        </h3>
        
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">
            Esta herramienta migra automáticamente todos los registros de la base de datos que dependan de un valor de diccionario específico hacia otro valor.<br/>
            <strong>Ejemplo:</strong> Cambiar el nivel de descripción "Collection" de todos los recursos e ítems de archivo simultáneamente hacia un nuevo término como "Fondo".
        </p>

        <form asp-action="BulkUpdateEnum" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Seleccionar Tabla/Lista</label>
                <select name="enumListId" required>
                    @foreach (var list in Model)
                    {
                        <option value="@list.Id">@list.Name</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Valor Antiguo (Old Value)</label>
                <input type="text" name="oldValue" class="form-control" placeholder="Ej. Collection" required />
                <small style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-top: 2px;">
                    El identificador exacto de base de datos a modificar.
                </small>
            </div>

            <div class="form-group" style="margin-bottom: 2rem;">
                <label class="form-label">Nuevo Valor (New Value)</label>
                <input type="text" name="newValue" class="form-control" placeholder="Ej. Fondo" required />
                <small style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-top: 2px;">
                    El identificador destino que lo reemplazará. Debe existir en el diccionario.
                </small>
            </div>

            <button type="submit" class="btn btn-warning" style="width: 100%; font-size: 1rem; padding: 0.75rem;">
                <i data-lucide="alert-triangle"></i> Ejecutar Migración Masiva
            </button>
        </form>
    </div>

</div>
